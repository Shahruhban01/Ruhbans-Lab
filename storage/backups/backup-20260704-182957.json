        "posts": [
            {
                "id": 1,
                "content_type_id": 4,
                "author_id": 1,
                "title": "Getting Started with Developer Ruhban",
                "slug": "getting-started-with-developer-ruhban",
                "excerpt": "A practical introduction to the platform structure, content flow, and SEO-first publishing model.",
                "content": "<p>Developer Ruhban is built to keep content fast to publish and easy to maintain.</p><h2>What this platform is</h2><p>It combines a custom MVC backend, a reusable content model, and a clean public frontend.</p><h2>What you can publish</h2><p>Tutorials, guides, notes, and reference material can all live in the same system.</p>",
                "featured_image": null,
                "status": "published",
                "visibility": "public",
                "reading_time": 6,
                "published_at": "2026-07-04 08:00:00",
                "featured_flag": 1,
                "created_at": "2026-07-04 08:00:00",
                "updated_at": "2026-07-04 08:00:00",
                "deleted_at": null
            },
            {
                "id": 2,
                "content_type_id": 3,
                "author_id": 1,
                "title": "Building SEO-Friendly Public Content Pages",
                "slug": "building-seo-friendly-public-content-pages",
                "excerpt": "A focused walkthrough of metadata, breadcrumbs, internal links, and structured public pages.",
                "content": "<p>Search engines reward clarity, structure, and internal linking.</p><h2>Core rules</h2><ul><li>Use descriptive titles.</li><li>Keep URLs short and readable.</li><li>Add a single H1 and consistent headings.</li></ul><h2>Page structure</h2><p>Every page should have a clear purpose and support one main topic.</p>",
                "featured_image": null,
                "status": "published",
                "visibility": "public",
                "reading_time": 7,
                "published_at": "2026-07-04 09:00:00",
                "featured_flag": 1,
                "created_at": "2026-07-04 09:00:00",
                "updated_at": "2026-07-04 09:00:00",
                "deleted_at": null
            },
            {
                "id": 3,
                "content_type_id": 1,
                "author_id": 1,
                "title": "Universal Content Workflow and Revisions",
                "slug": "universal-content-workflow-and-revisions",
                "excerpt": "A practical look at drafts, publishing, revision history, and metadata management.",
                "content": "<p>The universal content workflow starts with a draft and ends with a traceable revision history.</p><h2>Workflow</h2><p>Edit, preview, publish, schedule, and restore revisions from one place.</p><h2>Why revisions matter</h2><p>Version history keeps publishing safe when content changes over time.</p>",
                "featured_image": null,
                "status": "published",
                "visibility": "public",
                "reading_time": 5,
                "published_at": "2026-07-04 10:00:00",
                "featured_flag": 0,
                "created_at": "2026-07-04 10:00:00",
